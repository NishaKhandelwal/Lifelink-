        <script><![CDATA[(function executeRule(current, previous) {
    var userId = current.getValue('user');
    var currentUser = gs.getUserID();
    
    if (userId && userId !== currentUser && !gs.hasRole('x_1920732_lifeli_0.admin')) {
        gs.addErrorMessage('You can only create a donor profile for yourself.');
        current.setAbortAction(true);
        return;
    }
    
    // If user field is not set, set it to current user
    if (!userId) {
        current.setValue('user', currentUser);
    }
})(current, previous);
]]></script>
