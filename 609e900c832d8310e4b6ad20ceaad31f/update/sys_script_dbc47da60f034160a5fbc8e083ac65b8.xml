    <script><![CDATA[(function executeRule(current, previous) {
    var emergencyLevel = current.getValue('emergency_level');
    var priorityMap = {
        'low': '4',
        'medium': '3',
        'high': '2',
        'critical': '1'
    };

    if (emergencyLevel && priorityMap[emergencyLevel]) {
        current.setValue('priority', priorityMap[emergencyLevel]);
    }
})(current, previous);
